# Required: JSON string of service account key
# Example: {"type":"service_account","project_id":"my-project",...}
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional fallback if not in service account JSON
FIREBASE_PROJECT_ID=

# Required for Realtime Database connectivity check
FIREBASE_DATABASE_URL=

# Optional: user uid to verify custom claims/role assignment
FIREBASE_TEST_UID=

# Optional: comma-separated list of required roles
# Example: admin,editor,viewer
FIREBASE_REQUIRED_ROLES=
