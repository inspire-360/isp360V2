rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserRecord() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserRecord().data.role in [
          "admin",
          "Admin",
          "du admin",
          "DU Admin",
          "du_admin",
          "DU_ADMIN",
          "duadmin",
          "DUADMIN"
        ];
    }

    function isTeacher() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserRecord().data.role in [
          "teacher",
          "Teacher"
        ];
    }

    function validSelfUserCreate(userId) {
      return request.resource.data.keys().hasOnly([
          "uid",
          "prefix",
          "firstName",
          "lastName",
          "name",
          "position",
          "school",
          "email",
          "role",
          "activePath",
          "progress",
          "progressPercent",
          "status",
          "photoURL",
          "createdAt",
          "updatedAt",
          "lastLogin",
          "lastLoginAt",
          "memberStatus",
          "sourceProvider",
          "profileVersion",
          "pdpaAccepted",
          "pdpaAcceptedAt",
          "badges",
          "lineUserId"
        ])
        && request.resource.data.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.prefix is string
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.position is string
        && request.resource.data.school is string
        && request.resource.data.email is string
        && request.resource.data.role in ["teacher", "Teacher"]
        && request.resource.data.activePath == "/course/teacher"
        && request.resource.data.progress is int
        && request.resource.data.progress == 0
        && request.resource.data.progressPercent is int
        && request.resource.data.progressPercent == 0
        && request.resource.data.status == "active"
        && request.resource.data.photoURL is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastLogin is timestamp
        && request.resource.data.lastLoginAt is timestamp
        && request.resource.data.memberStatus == "active"
        && request.resource.data.sourceProvider is string
        && request.resource.data.sourceProvider.size() > 0
        && request.resource.data.profileVersion is int
        && request.resource.data.profileVersion >= 2
        && request.resource.data.pdpaAccepted == true
        && request.resource.data.pdpaAcceptedAt is timestamp
        && request.resource.data.badges is list
        && request.resource.data.lineUserId is string;
    }

    function validSelfUserUpdate(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "prefix",
          "firstName",
          "lastName",
          "name",
          "position",
          "school",
          "activePath",
          "progress",
          "progressPercent",
          "status",
          "photoURL",
          "updatedAt",
          "lastLogin",
          "lastLoginAt",
          "lastProgressAt",
          "lineUserId",
          "memberStatus",
          "sourceProvider",
          "profileVersion",
          "pdpaAccepted",
          "pdpaAcceptedAt",
          "badges"
        ])
        && request.resource.data.lastLoginAt is timestamp
        && request.resource.data.memberStatus is string
        && (
          request.resource.data.memberStatus == resource.data.memberStatus
          || (
            resource.data.memberStatus == null
            && request.resource.data.memberStatus == "active"
          )
        )
        && request.resource.data.sourceProvider is string
        && request.resource.data.sourceProvider.size() > 0
        && (
          request.resource.data.sourceProvider == resource.data.sourceProvider
          || resource.data.sourceProvider == null
        )
        && request.resource.data.profileVersion is int
        && request.resource.data.profileVersion >= 2
        && (
          request.resource.data.profileVersion == resource.data.profileVersion
          || resource.data.profileVersion == null
        );
    }

    function validPresenceWrite(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly([
          "uid",
          "name",
          "role",
          "photoURL",
          "activePath",
          "presenceState",
          "isOnline",
          "visibilityState",
          "lastActive",
          "lastActiveMs",
          "lastSeen",
          "lastSeenMs",
          "updatedAt",
          "updatedAtMs",
          "sessionId"
        ])
        && request.resource.data.name is string
        && request.resource.data.role is string
        && request.resource.data.photoURL is string
        && request.resource.data.activePath is string
        && request.resource.data.presenceState in ["online", "away", "offline"]
        && request.resource.data.isOnline is bool
        && request.resource.data.visibilityState in ["visible", "hidden"]
        && request.resource.data.lastActive is timestamp
        && request.resource.data.lastActiveMs is int
        && request.resource.data.lastSeen is timestamp
        && request.resource.data.lastSeenMs is int
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAtMs is int
        && (request.resource.data.sessionId == null || request.resource.data.sessionId is string);
    }

    function validOwnerSosCreate(userId) {
      return request.resource.data.requesterId == userId
        && request.resource.data.approvalState == "pending_review"
        && request.resource.data.status == "new"
        && request.resource.data.duResponse == ""
        && request.resource.data.helpDetails == "";
    }

    function validOwnerSosUpdate(userId) {
      return request.resource.data.requesterId == userId
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.approvalState == resource.data.approvalState
        && request.resource.data.duResponse == resource.data.duResponse
        && request.resource.data.helpDetails == resource.data.helpDetails
        && request.resource.data.assignedTeam == resource.data.assignedTeam
        && request.resource.data.lastTouchedBy == resource.data.lastTouchedBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "category",
          "tags",
          "riskLevel",
          "riskSort",
          "summary",
          "details",
          "location",
          "preferredChannel",
          "status",
          "updatedAt",
          "updates"
        ]);
    }

    function validSupportTicketStatus(status) {
      return status in ["pending", "investigating", "resolved"];
    }

    function validSupportTicketPriority(priority) {
      return priority in ["high", "medium", "low"];
    }

    function validSupportTicketCategory(category) {
      return category in ["learning", "platform", "account", "wellbeing", "other"];
    }

    function validSupportTicketCreate() {
      return request.resource.data.keys().hasOnly([
          "requesterId",
          "requesterName",
          "requesterEmail",
          "requesterRole",
          "subject",
          "category",
          "priority",
          "status",
          "createdAt",
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "assignedAdminId",
          "assignedAdminName",
          "resolvedAt",
          "messageCount"
        ])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.requesterName is string
        && request.resource.data.requesterEmail is string
        && request.resource.data.requesterRole is string
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && validSupportTicketCategory(request.resource.data.category)
        && validSupportTicketPriority(request.resource.data.priority)
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessagePreview.size() > 0
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole is string
        && request.resource.data.assignedAdminId == ""
        && request.resource.data.assignedAdminName == ""
        && request.resource.data.resolvedAt == null
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount == 1;
    }

    function validOwnerTicketUpdate() {
      return request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterName == resource.data.requesterName
        && request.resource.data.requesterEmail == resource.data.requesterEmail
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.subject == resource.data.subject
        && request.resource.data.category == resource.data.category
        && request.resource.data.priority == resource.data.priority
        && request.resource.data.status == resource.data.status
        && request.resource.data.assignedAdminId == resource.data.assignedAdminId
        && request.resource.data.assignedAdminName == resource.data.assignedAdminName
        && request.resource.data.resolvedAt == resource.data.resolvedAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole is string
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount == resource.data.messageCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "messageCount"
        ]);
    }

    function validAdminTicketUpdate() {
      return request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterName == resource.data.requesterName
        && request.resource.data.requesterEmail == resource.data.requesterEmail
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.subject == resource.data.subject
        && request.resource.data.category == resource.data.category
        && request.resource.data.priority == resource.data.priority
        && validSupportTicketStatus(request.resource.data.status)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole == "admin"
        && request.resource.data.assignedAdminId is string
        && request.resource.data.assignedAdminName is string
        && (
          (request.resource.data.status == "resolved" && request.resource.data.resolvedAt is timestamp)
          || (request.resource.data.status != "resolved" && request.resource.data.resolvedAt == null)
        )
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount == resource.data.messageCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "assignedAdminId",
          "assignedAdminName",
          "resolvedAt",
          "messageCount"
        ]);
    }

    function validSupportTicketMessageCreate(ticketId) {
      return exists(/databases/$(database)/documents/supportTickets/$(ticketId))
        && request.resource.data.keys().hasOnly([
          "ticketId",
          "authorId",
          "authorName",
          "authorRole",
          "body",
          "createdAt"
        ])
        && request.resource.data.ticketId == ticketId
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorRole is string
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.createdAt is timestamp;
    }

    function validSosTicketStatus(status) {
      return status in ["รอดำเนินการ", "กำลังช่วยเหลือ", "ปิดงาน"];
    }

    function validSosUrgencyLevel(level) {
      return level in [
        "ฉุกเฉินวิกฤต",
        "ฉุกเฉินหนัก",
        "ฉุกเฉิน",
        "ฉุกเฉินไม่เร่งด่วน",
        "เรื่องทั่วไป"
      ];
    }

    function validSosMainCategory(category) {
      return category in [
        "หมวดงาน",
        "หมวดสถานที่และอุปกรณ์",
        "หมวดความสัมพันธ์",
        "หมวดสุขภาพกาย",
        "หมวดสุขภาพจิต"
      ];
    }

    function validSosSubCategory(mainCategory, subCategory) {
      return (
        mainCategory == "หมวดงาน"
        && subCategory in [
          "งานสอนและเตรียมสอน",
          "งานเอกสาร/ประเมิน",
          "งานพิเศษ/กิจกรรม",
          "ผลกระทบจากนโยบาย"
        ]
      ) || (
        mainCategory == "หมวดสถานที่และอุปกรณ์"
        && subCategory in [
          "ซ่อมบำรุงอาคาร/พื้นที่",
          "อุปกรณ์การสอนชำรุด/ขาดแคลน",
          "ระบบ IT/อินเทอร์เน็ต",
          "ความปลอดภัย/สภาพแวดล้อม"
        ]
      ) || (
        mainCategory == "หมวดความสัมพันธ์"
        && subCategory in [
          "ปัญหาพฤติกรรมนักเรียน",
          "การสื่อสารกับผู้ปกครอง",
          "บรรยากาศเพื่อนร่วมงาน",
          "การบริหารของผู้บังคับบัญชา",
          "การถูกคุกคาม/กลั่นแกล้ง"
        ]
      ) || (
        mainCategory == "หมวดสุขภาพกาย"
        && subCategory in [
          "ออฟฟิศซินโดรม",
          "ปัญหาเส้นเสียง/ทางเดินหายใจ",
          "ความอ่อนล้าสะสม",
          "ปัญหาสุขภาพเรื้อรัง"
        ]
      ) || (
        mainCategory == "หมวดสุขภาพจิต"
        && subCategory in [
          "ภาวะหมดไฟ (Burnout)",
          "ความเครียด/วิตกกังวลสูง",
          "ต้องการที่ปรึกษาทางจิตวิทยา",
          "ปัญหาภาระหนี้สิน"
        ]
      );
    }

    function validSosTicketDocumentShape() {
      return request.resource.data.keys().hasOnly([
          "requesterId",
          "requesterDisplayName",
          "requesterRole",
          "topic",
          "mainCategory",
          "subCategory",
          "urgencyLevel",
          "location",
          "details",
          "contactInfo",
          "isConfidential",
          "status",
          "assignedTo",
          "createdAt",
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "closedAt",
          "messageCount"
        ])
        && request.resource.data.requesterId is string
        && request.resource.data.requesterId.size() > 0
        && request.resource.data.requesterDisplayName is string
        && request.resource.data.requesterDisplayName.size() > 0
        && request.resource.data.requesterRole in ["teacher", "Teacher"]
        && request.resource.data.topic is string
        && request.resource.data.topic.size() > 0
        && validSosMainCategory(request.resource.data.mainCategory)
        && validSosSubCategory(
          request.resource.data.mainCategory,
          request.resource.data.subCategory
        )
        && validSosUrgencyLevel(request.resource.data.urgencyLevel)
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && request.resource.data.details is string
        && request.resource.data.details.size() > 0
        && request.resource.data.contactInfo is string
        && request.resource.data.contactInfo.size() > 0
        && request.resource.data.isConfidential is bool
        && validSosTicketStatus(request.resource.data.status)
        && request.resource.data.assignedTo is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessagePreview.size() > 0
        && request.resource.data.lastMessageAuthorId is string
        && request.resource.data.lastMessageAuthorRole in ["teacher", "Teacher", "admin"]
        && (
          request.resource.data.closedAt == null
          || request.resource.data.closedAt is timestamp
        )
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount > 0;
    }

    function validTeacherSosTicketCreate() {
      return validSosTicketDocumentShape()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == "รอดำเนินการ"
        && request.resource.data.assignedTo == ""
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole in ["teacher", "Teacher"]
        && request.resource.data.closedAt == null
        && request.resource.data.messageCount == 1;
    }

    function validTeacherSosTicketUpdate() {
      return validSosTicketDocumentShape()
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.requesterDisplayName == resource.data.requesterDisplayName
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.topic == resource.data.topic
        && request.resource.data.mainCategory == resource.data.mainCategory
        && request.resource.data.subCategory == resource.data.subCategory
        && request.resource.data.urgencyLevel == resource.data.urgencyLevel
        && request.resource.data.location == resource.data.location
        && request.resource.data.details == resource.data.details
        && request.resource.data.contactInfo == resource.data.contactInfo
        && request.resource.data.isConfidential == resource.data.isConfidential
        && request.resource.data.status == resource.data.status
        && request.resource.data.assignedTo == resource.data.assignedTo
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole in ["teacher", "Teacher"]
        && request.resource.data.closedAt == resource.data.closedAt
        && request.resource.data.messageCount == resource.data.messageCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "messageCount"
        ]);
    }

    function validAdminSosTicketUpdate() {
      return validSosTicketDocumentShape()
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterDisplayName == resource.data.requesterDisplayName
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.topic == resource.data.topic
        && request.resource.data.mainCategory == resource.data.mainCategory
        && request.resource.data.subCategory == resource.data.subCategory
        && request.resource.data.urgencyLevel == resource.data.urgencyLevel
        && request.resource.data.location == resource.data.location
        && request.resource.data.details == resource.data.details
        && request.resource.data.contactInfo == resource.data.contactInfo
        && request.resource.data.isConfidential == resource.data.isConfidential
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole == "admin"
        && request.resource.data.messageCount == resource.data.messageCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "assignedTo",
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "closedAt",
          "messageCount"
        ])
        && (
          (
            request.resource.data.status == "ปิดงาน"
            && request.resource.data.closedAt is timestamp
          )
          || (
            request.resource.data.status != "ปิดงาน"
            && request.resource.data.closedAt == null
          )
        );
    }

    function validSosTicketMessageCreate(ticketId) {
      return request.resource.data.keys().hasOnly([
          "ticketId",
          "authorId",
          "authorName",
          "authorRole",
          "body",
          "createdAt"
        ])
        && request.resource.data.ticketId == ticketId
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && (
          (isAdmin() && request.resource.data.authorRole == "admin")
          || (!isAdmin() && request.resource.data.authorRole in ["teacher", "Teacher"])
        )
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.createdAt is timestamp;
    }

    function teacherOwnsSosTicketNowOrAfterCreate(ticketId) {
      return (
        exists(/databases/$(database)/documents/sos_tickets/$(ticketId))
        && get(/databases/$(database)/documents/sos_tickets/$(ticketId)).data.requesterId == request.auth.uid
      ) || (
        !exists(/databases/$(database)/documents/sos_tickets/$(ticketId))
        && getAfter(/databases/$(database)/documents/sos_tickets/$(ticketId)).data.requesterId == request.auth.uid
      );
    }

    function validVideoReviewStatus(status) {
      return status in ["pending_feedback", "coaching", "reviewed"];
    }

    function canReadVideoData(videoData) {
      return isAdmin()
        || (signedIn() && videoData.teacherId == request.auth.uid)
        || (
          signedIn()
          && videoData.assignedCoachIds is list
          && request.auth.uid in videoData.assignedCoachIds
        );
    }

    function canReadVideoDoc(videoId) {
      return exists(/databases/$(database)/documents/videos/$(videoId))
        && canReadVideoData(get(/databases/$(database)/documents/videos/$(videoId)).data);
    }

    function validVideoDocumentShape() {
      return request.resource.data.keys().hasOnly([
          "teacherId",
          "teacherName",
          "courseId",
          "enrollmentId",
          "sourceEnrollmentPath",
          "sourceMissionId",
          "sourceMissionUpdatedAt",
          "title",
          "description",
          "subject",
          "schoolName",
          "videoUrl",
          "durationSeconds",
          "reviewStatus",
          "assignedCoachIds",
          "submittedAt",
          "updatedAt",
          "lastCommentAt",
          "lastCommentPreview",
          "commentCount"
        ])
        && request.resource.data.teacherId is string
        && request.resource.data.teacherId.size() > 0
        && request.resource.data.teacherName is string
        && request.resource.data.teacherName.size() > 0
        && request.resource.data.courseId is string
        && request.resource.data.courseId.size() > 0
        && request.resource.data.enrollmentId is string
        && request.resource.data.enrollmentId.size() > 0
        && request.resource.data.sourceEnrollmentPath is string
        && request.resource.data.sourceMissionId is string
        && request.resource.data.sourceMissionId.size() > 0
        && (
          request.resource.data.sourceMissionUpdatedAt == null
          || request.resource.data.sourceMissionUpdatedAt is timestamp
        )
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.description is string
        && request.resource.data.subject is string
        && request.resource.data.schoolName is string
        && request.resource.data.videoUrl is string
        && request.resource.data.videoUrl.size() > 0
        && (
          request.resource.data.durationSeconds == null
          || request.resource.data.durationSeconds is int
        )
        && validVideoReviewStatus(request.resource.data.reviewStatus)
        && request.resource.data.assignedCoachIds is list
        && request.resource.data.submittedAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.lastCommentAt == null
          || request.resource.data.lastCommentAt is timestamp
        )
        && request.resource.data.lastCommentPreview is string
        && request.resource.data.commentCount is int
        && request.resource.data.commentCount >= 0;
    }

    function validTeacherVideoCreate() {
      return validVideoDocumentShape()
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.reviewStatus == "pending_feedback"
        && request.resource.data.lastCommentAt == null
        && request.resource.data.lastCommentPreview == ""
        && request.resource.data.commentCount == 0;
    }

    function validAdminVideoCreate() {
      return validVideoDocumentShape()
        && request.resource.data.lastCommentAt == null
        && request.resource.data.lastCommentPreview == ""
        && request.resource.data.commentCount == 0;
    }

    function validAdminVideoUpdate() {
      return validVideoDocumentShape()
        && request.resource.data.teacherId == resource.data.teacherId
        && (
          resource.data.courseId == null
          || request.resource.data.courseId == resource.data.courseId
        )
        && (
          resource.data.enrollmentId == null
          || request.resource.data.enrollmentId == resource.data.enrollmentId
        )
        && (
          resource.data.sourceEnrollmentPath == null
          || request.resource.data.sourceEnrollmentPath == resource.data.sourceEnrollmentPath
        )
        && (
          resource.data.sourceMissionId == null
          || request.resource.data.sourceMissionId == resource.data.sourceMissionId
        )
        && request.resource.data.submittedAt == resource.data.submittedAt;
    }

    function validVideoCommentBase(videoId) {
      return exists(/databases/$(database)/documents/videos/$(videoId))
        && request.resource.data.keys().hasOnly([
          "videoId",
          "teacherId",
          "authorId",
          "authorName",
          "authorRole",
          "body",
          "timestampSeconds",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.videoId == videoId
        && request.resource.data.teacherId
          == get(/databases/$(database)/documents/videos/$(videoId)).data.teacherId
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorRole == "admin"
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.timestampSeconds is int
        && request.resource.data.timestampSeconds >= 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validVideoCommentCreate(videoId) {
      return validVideoCommentBase(videoId);
    }

    function validVideoCommentUpdate(videoId) {
      return validVideoCommentBase(videoId)
        && request.resource.data.videoId == resource.data.videoId
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.authorName == resource.data.authorName
        && request.resource.data.authorRole == resource.data.authorRole
        && request.resource.data.timestampSeconds == resource.data.timestampSeconds
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "body",
          "updatedAt"
        ]);
    }

    function validExpertCapacityStatus(status) {
      return status in ["available", "limited", "paused"];
    }

    function validPreferredSupportFormat(format) {
      return format in ["online", "onsite", "hybrid"];
    }

    function validMatchRequestStatus(status) {
      return status in ["pending_match", "matched", "completed"];
    }

    function validMatchRequestPriority(priority) {
      return priority in ["high", "medium", "low"];
    }

    function validMatchResourceType(resourceType) {
      return resourceType in ["consultation", "coaching", "workshop", "resource_pack"];
    }

    function validMatchClosedReason(reason) {
      return reason in ["", "resolved", "follow_up", "handoff", "teacher_withdrew"];
    }

    function validShortStringList(value, maxItems) {
      return value is list
        && value.size() <= maxItems;
    }

    function validRequesterProfileSnapshot(snapshot) {
      return snapshot is map
        && snapshot.keys().hasOnly([
          "name",
          "role",
          "school",
          "position",
          "memberStatus",
          "sourceProvider"
        ])
        && snapshot.name is string
        && snapshot.name.size() > 0
        && snapshot.role is string
        && snapshot.role.size() > 0
        && snapshot.school is string
        && snapshot.position is string
        && snapshot.memberStatus is string
        && snapshot.memberStatus.size() > 0
        && snapshot.sourceProvider is string
        && snapshot.sourceProvider.size() > 0;
    }

    function emptyMatchedExpertSnapshot(snapshot) {
      return snapshot is map && snapshot.keys().size() == 0;
    }

    function validMatchedExpertSnapshot(snapshot) {
      return snapshot is map
        && snapshot.keys().hasOnly([
          "id",
          "name",
          "title",
          "organization",
          "primaryExpertise",
          "region",
          "serviceModes",
          "expertiseTags",
          "capacityStatus"
        ])
        && snapshot.id is string
        && snapshot.id.size() > 0
        && snapshot.name is string
        && snapshot.name.size() > 0
        && snapshot.title is string
        && snapshot.organization is string
        && snapshot.primaryExpertise is string
        && snapshot.region is string
        && validShortStringList(snapshot.serviceModes, 6)
        && validShortStringList(snapshot.expertiseTags, 12)
        && validExpertCapacityStatus(snapshot.capacityStatus);
    }

    function validExpertDocumentShape() {
      return request.resource.data.keys().hasOnly([
          "displayName",
          "title",
          "organization",
          "primaryExpertise",
          "expertiseTags",
          "serviceModes",
          "region",
          "bio",
          "contactEmail",
          "contactLine",
          "isActive",
          "capacityStatus",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.title is string
        && request.resource.data.organization is string
        && request.resource.data.primaryExpertise is string
        && request.resource.data.primaryExpertise.size() > 0
        && request.resource.data.expertiseTags is list
        && request.resource.data.serviceModes is list
        && request.resource.data.region is string
        && request.resource.data.bio is string
        && request.resource.data.contactEmail is string
        && request.resource.data.contactLine is string
        && request.resource.data.isActive is bool
        && validExpertCapacityStatus(request.resource.data.capacityStatus)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validExpertCreate() {
      return validExpertDocumentShape();
    }

    function validExpertUpdate() {
      return validExpertDocumentShape()
        && (
          request.resource.data.createdAt == resource.data.createdAt
          || resource.data.createdAt == null
        );
    }

    function validTeacherMatchRequestCreate() {
      return request.resource.data.keys().hasOnly([
          "requesterId",
          "requesterName",
          "requesterRole",
          "schoolName",
          "requestTitle",
          "desiredExpertise",
          "preferredFormat",
          "requestDetails",
          "priority",
          "resourceType",
          "needTags",
          "requesterProfileSnapshot",
          "status",
          "createdAt",
          "updatedAt",
          "matchedExpertId",
          "matchedExpertName",
          "matchedExpertTitle",
          "matchedExpertPrimaryExpertise",
          "matchedExpertSnapshot",
          "matchedByAdminId",
          "matchedByAdminName",
          "matchedAt",
          "completedAt",
          "closedReason",
          "adminNote",
          "latestUpdateText"
        ])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.requesterName is string
        && request.resource.data.requesterName.size() > 0
        && request.resource.data.requesterRole == "teacher"
        && request.resource.data.schoolName is string
        && request.resource.data.requestTitle is string
        && request.resource.data.requestTitle.size() > 0
        && request.resource.data.desiredExpertise is string
        && request.resource.data.desiredExpertise.size() > 0
        && validPreferredSupportFormat(request.resource.data.preferredFormat)
        && request.resource.data.requestDetails is string
        && request.resource.data.requestDetails.size() > 0
        && validMatchRequestPriority(request.resource.data.priority)
        && validMatchResourceType(request.resource.data.resourceType)
        && validShortStringList(request.resource.data.needTags, 8)
        && validRequesterProfileSnapshot(request.resource.data.requesterProfileSnapshot)
        && request.resource.data.requesterProfileSnapshot.name == request.resource.data.requesterName
        && request.resource.data.requesterProfileSnapshot.role == request.resource.data.requesterRole
        && request.resource.data.requesterProfileSnapshot.school == request.resource.data.schoolName
        && request.resource.data.status == "pending_match"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.matchedExpertId == ""
        && request.resource.data.matchedExpertName == ""
        && request.resource.data.matchedExpertTitle == ""
        && request.resource.data.matchedExpertPrimaryExpertise == ""
        && emptyMatchedExpertSnapshot(request.resource.data.matchedExpertSnapshot)
        && request.resource.data.matchedByAdminId == ""
        && request.resource.data.matchedByAdminName == ""
        && request.resource.data.matchedAt == null
        && request.resource.data.completedAt == null
        && request.resource.data.closedReason == ""
        && request.resource.data.adminNote == ""
        && request.resource.data.latestUpdateText is string
        && request.resource.data.latestUpdateText.size() > 0;
    }

    function validAdminMatchRequestUpdate() {
      return request.resource.data.keys().hasOnly([
          "requesterId",
          "requesterName",
          "requesterRole",
          "schoolName",
          "requestTitle",
          "desiredExpertise",
          "preferredFormat",
          "requestDetails",
          "priority",
          "resourceType",
          "needTags",
          "requesterProfileSnapshot",
          "status",
          "createdAt",
          "updatedAt",
          "matchedExpertId",
          "matchedExpertName",
          "matchedExpertTitle",
          "matchedExpertPrimaryExpertise",
          "matchedExpertSnapshot",
          "matchedByAdminId",
          "matchedByAdminName",
          "matchedAt",
          "completedAt",
          "closedReason",
          "adminNote",
          "latestUpdateText"
        ])
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterName == resource.data.requesterName
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.schoolName == resource.data.schoolName
        && request.resource.data.requestTitle == resource.data.requestTitle
        && request.resource.data.desiredExpertise == resource.data.desiredExpertise
        && request.resource.data.preferredFormat == resource.data.preferredFormat
        && validPreferredSupportFormat(request.resource.data.preferredFormat)
        && request.resource.data.requestDetails == resource.data.requestDetails
        && validMatchRequestPriority(request.resource.data.priority)
        && (
          request.resource.data.priority == resource.data.priority
          || resource.data.priority == null
        )
        && validMatchResourceType(request.resource.data.resourceType)
        && (
          request.resource.data.resourceType == resource.data.resourceType
          || resource.data.resourceType == null
        )
        && validShortStringList(request.resource.data.needTags, 8)
        && (
          request.resource.data.needTags == resource.data.needTags
          || resource.data.needTags == null
        )
        && validRequesterProfileSnapshot(request.resource.data.requesterProfileSnapshot)
        && (
          request.resource.data.requesterProfileSnapshot == resource.data.requesterProfileSnapshot
          || resource.data.requesterProfileSnapshot == null
        )
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && validMatchRequestStatus(request.resource.data.status)
        && request.resource.data.matchedExpertId is string
        && request.resource.data.matchedExpertName is string
        && request.resource.data.matchedExpertTitle is string
        && request.resource.data.matchedExpertPrimaryExpertise is string
        && validMatchClosedReason(request.resource.data.closedReason)
        && request.resource.data.matchedByAdminId is string
        && request.resource.data.matchedByAdminName is string
        && request.resource.data.adminNote is string
        && request.resource.data.latestUpdateText is string
        && request.resource.data.latestUpdateText.size() > 0
        && (
          (
            request.resource.data.status == "pending_match"
            && request.resource.data.matchedExpertId == ""
            && request.resource.data.matchedExpertName == ""
            && request.resource.data.matchedExpertTitle == ""
            && request.resource.data.matchedExpertPrimaryExpertise == ""
            && emptyMatchedExpertSnapshot(request.resource.data.matchedExpertSnapshot)
            && request.resource.data.matchedByAdminId == ""
            && request.resource.data.matchedByAdminName == ""
            && request.resource.data.matchedAt == null
            && request.resource.data.completedAt == null
            && request.resource.data.closedReason == ""
          )
          || (
            request.resource.data.status == "matched"
            && request.resource.data.matchedExpertId.size() > 0
            && request.resource.data.matchedExpertName.size() > 0
            && validMatchedExpertSnapshot(request.resource.data.matchedExpertSnapshot)
            && request.resource.data.matchedExpertSnapshot.id == request.resource.data.matchedExpertId
            && request.resource.data.matchedExpertSnapshot.name == request.resource.data.matchedExpertName
            && request.resource.data.matchedAt is timestamp
            && request.resource.data.completedAt == null
            && request.resource.data.closedReason == ""
            && request.resource.data.matchedByAdminId.size() > 0
            && request.resource.data.matchedByAdminName.size() > 0
          )
          || (
            request.resource.data.status == "completed"
            && request.resource.data.matchedExpertId.size() > 0
            && request.resource.data.matchedExpertName.size() > 0
            && validMatchedExpertSnapshot(request.resource.data.matchedExpertSnapshot)
            && request.resource.data.matchedExpertSnapshot.id == request.resource.data.matchedExpertId
            && request.resource.data.matchedExpertSnapshot.name == request.resource.data.matchedExpertName
            && request.resource.data.matchedAt is timestamp
            && request.resource.data.completedAt is timestamp
            && request.resource.data.closedReason != ""
            && request.resource.data.matchedByAdminId.size() > 0
            && request.resource.data.matchedByAdminName.size() > 0
          )
        );
    }

    function validInnovationStage(stage) {
      return stage in [
        "idea",
        "prototype",
        "funded",
        "best_practice",
        "ไอเดียเบื้องต้น",
        "กำลังพัฒนาต้นแบบ",
        "กำลังพัฒนา (Prototype)",
        "ได้รับทุนตั้งต้น",
        "ได้รับทุน (Seed Funding)",
        "Best Practice",
        "แนวปฏิบัติที่เป็นเลิศ"
      ];
    }

    function validInitialInnovationStage(stage) {
      return stage in ["idea", "ไอเดียเบื้องต้น"];
    }

    function validInnovationDocumentShape() {
      return request.resource.data.keys().hasOnly([
          "teacherId",
          "teacherName",
          "schoolName",
          "title",
          "summary",
          "focusArea",
          "supportNeed",
          "tags",
          "stage",
          "evidenceNote",
          "createdAt",
          "updatedAt",
          "lastMovedAt",
          "lastMovedById",
          "lastMovedByName"
        ])
        && request.resource.data.teacherId is string
        && request.resource.data.teacherId.size() > 0
        && request.resource.data.teacherName is string
        && request.resource.data.teacherName.size() > 0
        && request.resource.data.schoolName is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.summary is string
        && request.resource.data.focusArea is string
        && request.resource.data.supportNeed is string
        && request.resource.data.tags is list
        && validInnovationStage(request.resource.data.stage)
        && request.resource.data.evidenceNote is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.lastMovedAt == null
          || request.resource.data.lastMovedAt is timestamp
        )
        && request.resource.data.lastMovedById is string
        && request.resource.data.lastMovedByName is string;
    }

    function validTeacherInnovationCreate() {
      return validInnovationDocumentShape()
        && request.resource.data.teacherId == request.auth.uid
        && validInitialInnovationStage(request.resource.data.stage)
        && request.resource.data.lastMovedAt == null
        && request.resource.data.lastMovedById == ""
        && request.resource.data.lastMovedByName == "";
    }

    function validTeacherInnovationUpdate() {
      return validInnovationDocumentShape()
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.teacherId == request.auth.uid
        && request.resource.data.stage == resource.data.stage
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.lastMovedAt == resource.data.lastMovedAt
        && request.resource.data.lastMovedById == resource.data.lastMovedById
        && request.resource.data.lastMovedByName == resource.data.lastMovedByName
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "teacherName",
          "schoolName",
          "title",
          "summary",
          "focusArea",
          "supportNeed",
          "tags",
          "evidenceNote",
          "updatedAt"
        ]);
    }

    function validAdminInnovationCreate() {
      return validInnovationDocumentShape()
        && (
          (
            request.resource.data.lastMovedAt == null
            && request.resource.data.lastMovedById == ""
            && request.resource.data.lastMovedByName == ""
          )
          || (
            request.resource.data.lastMovedAt is timestamp
            && request.resource.data.lastMovedById.size() > 0
            && request.resource.data.lastMovedByName.size() > 0
          )
        );
    }

    function validAdminInnovationUpdate() {
      return validInnovationDocumentShape()
        && request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (
            request.resource.data.stage == resource.data.stage
            && request.resource.data.lastMovedAt == resource.data.lastMovedAt
            && request.resource.data.lastMovedById == resource.data.lastMovedById
            && request.resource.data.lastMovedByName == resource.data.lastMovedByName
          )
          || (
            request.resource.data.stage != resource.data.stage
            && request.resource.data.lastMovedAt is timestamp
            && request.resource.data.lastMovedById == request.auth.uid
            && request.resource.data.lastMovedByName.size() > 0
          )
        );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && validSelfUserCreate(userId);
      allow update: if isAdmin() || (isOwner(userId) && validSelfUserUpdate(userId));
      allow delete: if isAdmin();

      match /enrollments/{enrollmentId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();

        match /mission_responses/{missionId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create, update, delete: if isOwner(userId) || isAdmin();
        }
      }

      match /sosCases/{caseId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isAdmin() || (isOwner(userId) && validOwnerSosCreate(userId));
        allow update: if isAdmin() || (isOwner(userId) && validOwnerSosUpdate(userId));
        allow delete: if isAdmin();
      }
    }

    match /{path=**}/enrollments/{enrollmentId} {
      allow get, list: if isAdmin();
    }

    match /{path=**}/mission_responses/{missionId} {
      allow get, list: if isAdmin();
    }

    match /presence/{userId} {
      allow get, list: if signedIn();
      allow create, update: if isOwner(userId) && validPresenceWrite(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /videos/{videoId} {
      allow get: if canReadVideoData(resource.data);
      allow list: if isAdmin();
      allow create: if (signedIn() && validTeacherVideoCreate())
        || (isAdmin() && validAdminVideoCreate());
      allow update: if isAdmin() && validAdminVideoUpdate();
      allow delete: if isAdmin();

      match /video_comments/{commentId} {
        allow get, list: if canReadVideoDoc(videoId);
        allow create: if isAdmin() && validVideoCommentCreate(videoId);
        allow update: if isAdmin() && validVideoCommentUpdate(videoId);
        allow delete: if isAdmin();
      }
    }

    match /experts/{expertId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && validExpertCreate();
      allow update: if isAdmin() && validExpertUpdate();
      allow delete: if isAdmin();
    }

    match /match_requests/{requestId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if signedIn() && validTeacherMatchRequestCreate();
      allow update: if isAdmin() && validAdminMatchRequestUpdate();
      allow delete: if false;
    }

    match /innovations/{innovationId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.teacherId == request.auth.uid);
      allow create: if (isTeacher() && validTeacherInnovationCreate())
        || (isAdmin() && validAdminInnovationCreate());
      allow update: if (isTeacher() && resource.data.teacherId == request.auth.uid && validTeacherInnovationUpdate())
        || (isAdmin() && validAdminInnovationUpdate());
      allow delete: if isAdmin();
    }

    match /sos_tickets/{ticketId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if signedIn() && validTeacherSosTicketCreate();
      allow update: if (isTeacher() && resource.data.requesterId == request.auth.uid && validTeacherSosTicketUpdate())
        || (isAdmin() && validAdminSosTicketUpdate());
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/sos_tickets/$(ticketId)).data.requesterId == request.auth.uid
          );
        allow create: if (
          isAdmin()
          || (
            isTeacher()
            && teacherOwnsSosTicketNowOrAfterCreate(ticketId)
          )
        ) && validSosTicketMessageCreate(ticketId);
        allow update, delete: if false;
      }
    }

    match /duSosCases/{caseId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && validOwnerSosCreate(request.auth.uid));
      allow update: if isAdmin() || (signedIn() && validOwnerSosUpdate(request.auth.uid));
      allow delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if signedIn() && validSupportTicketCreate();
      allow update: if (signedIn() && resource.data.requesterId == request.auth.uid && validOwnerTicketUpdate())
        || (isAdmin() && validAdminTicketUpdate());
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.requesterId == request.auth.uid
          );
        allow create: if (
          isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.requesterId == request.auth.uid
          )
        ) && validSupportTicketMessageCreate(ticketId);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
