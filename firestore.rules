rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserRecord() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserRecord().data.role in [
          "admin",
          "Admin",
          "du admin",
          "DU Admin",
          "du_admin",
          "DU_ADMIN",
          "duadmin",
          "DUADMIN"
        ];
    }

    function validSelfUserCreate(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "learner";
    }

    function validSelfUserUpdate(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "prefix",
          "firstName",
          "lastName",
          "name",
          "position",
          "school",
          "photoURL",
          "updatedAt",
          "lastLogin",
          "lineUserId",
          "pdpaAccepted",
          "pdpaAcceptedAt"
        ]);
    }

    function validPresenceWrite(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly([
          "uid",
          "name",
          "role",
          "photoURL",
          "activePath",
          "presenceState",
          "isOnline",
          "visibilityState",
          "lastActive",
          "lastActiveMs",
          "lastSeen",
          "lastSeenMs",
          "updatedAt",
          "updatedAtMs",
          "sessionId"
        ])
        && request.resource.data.name is string
        && request.resource.data.role is string
        && request.resource.data.photoURL is string
        && request.resource.data.activePath is string
        && request.resource.data.presenceState in ["online", "away", "offline"]
        && request.resource.data.isOnline is bool
        && request.resource.data.visibilityState in ["visible", "hidden"]
        && request.resource.data.lastActive is timestamp
        && request.resource.data.lastActiveMs is int
        && request.resource.data.lastSeen is timestamp
        && request.resource.data.lastSeenMs is int
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAtMs is int
        && (request.resource.data.sessionId == null || request.resource.data.sessionId is string);
    }

    function validOwnerSosCreate(userId) {
      return request.resource.data.requesterId == userId
        && request.resource.data.approvalState == "pending_review"
        && request.resource.data.status == "new"
        && request.resource.data.duResponse == ""
        && request.resource.data.helpDetails == "";
    }

    function validOwnerSosUpdate(userId) {
      return request.resource.data.requesterId == userId
        && request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.approvalState == resource.data.approvalState
        && request.resource.data.duResponse == resource.data.duResponse
        && request.resource.data.helpDetails == resource.data.helpDetails
        && request.resource.data.assignedTeam == resource.data.assignedTeam
        && request.resource.data.lastTouchedBy == resource.data.lastTouchedBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "category",
          "tags",
          "riskLevel",
          "riskSort",
          "summary",
          "details",
          "location",
          "preferredChannel",
          "status",
          "updatedAt",
          "updates"
        ]);
    }

    function validSupportTicketStatus(status) {
      return status in ["pending", "investigating", "resolved"];
    }

    function validSupportTicketPriority(priority) {
      return priority in ["high", "medium", "low"];
    }

    function validSupportTicketCategory(category) {
      return category in ["learning", "platform", "account", "wellbeing", "other"];
    }

    function validSupportTicketCreate() {
      return request.resource.data.keys().hasOnly([
          "requesterId",
          "requesterName",
          "requesterEmail",
          "requesterRole",
          "subject",
          "category",
          "priority",
          "status",
          "createdAt",
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "assignedAdminId",
          "assignedAdminName",
          "resolvedAt",
          "messageCount"
        ])
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.requesterName is string
        && request.resource.data.requesterEmail is string
        && request.resource.data.requesterRole is string
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && validSupportTicketCategory(request.resource.data.category)
        && validSupportTicketPriority(request.resource.data.priority)
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessagePreview.size() > 0
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole is string
        && request.resource.data.assignedAdminId == ""
        && request.resource.data.assignedAdminName == ""
        && request.resource.data.resolvedAt == null
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount == 1;
    }

    function validOwnerTicketUpdate() {
      return request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterName == resource.data.requesterName
        && request.resource.data.requesterEmail == resource.data.requesterEmail
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.subject == resource.data.subject
        && request.resource.data.category == resource.data.category
        && request.resource.data.priority == resource.data.priority
        && request.resource.data.status == resource.data.status
        && request.resource.data.assignedAdminId == resource.data.assignedAdminId
        && request.resource.data.assignedAdminName == resource.data.assignedAdminName
        && request.resource.data.resolvedAt == resource.data.resolvedAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole is string
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount == resource.data.messageCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "messageCount"
        ]);
    }

    function validAdminTicketUpdate() {
      return request.resource.data.requesterId == resource.data.requesterId
        && request.resource.data.requesterName == resource.data.requesterName
        && request.resource.data.requesterEmail == resource.data.requesterEmail
        && request.resource.data.requesterRole == resource.data.requesterRole
        && request.resource.data.subject == resource.data.subject
        && request.resource.data.category == resource.data.category
        && request.resource.data.priority == resource.data.priority
        && validSupportTicketStatus(request.resource.data.status)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessageAuthorId == request.auth.uid
        && request.resource.data.lastMessageAuthorRole == "admin"
        && request.resource.data.assignedAdminId is string
        && request.resource.data.assignedAdminName is string
        && (
          (request.resource.data.status == "resolved" && request.resource.data.resolvedAt is timestamp)
          || (request.resource.data.status != "resolved" && request.resource.data.resolvedAt == null)
        )
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount == resource.data.messageCount + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "updatedAt",
          "lastMessageAt",
          "lastMessagePreview",
          "lastMessageAuthorId",
          "lastMessageAuthorRole",
          "assignedAdminId",
          "assignedAdminName",
          "resolvedAt",
          "messageCount"
        ]);
    }

    function validSupportTicketMessageCreate(ticketId) {
      return exists(/databases/$(database)/documents/supportTickets/$(ticketId))
        && request.resource.data.keys().hasOnly([
          "ticketId",
          "authorId",
          "authorName",
          "authorRole",
          "body",
          "createdAt"
        ])
        && request.resource.data.ticketId == ticketId
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorRole is string
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && validSelfUserCreate(userId);
      allow update: if isAdmin() || (isOwner(userId) && validSelfUserUpdate(userId));
      allow delete: if isAdmin();

      match /enrollments/{enrollmentId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /sosCases/{caseId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isAdmin() || (isOwner(userId) && validOwnerSosCreate(userId));
        allow update: if isAdmin() || (isOwner(userId) && validOwnerSosUpdate(userId));
        allow delete: if isAdmin();
      }
    }

    match /presence/{userId} {
      allow get, list: if signedIn();
      allow create, update: if isOwner(userId) && validPresenceWrite(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /duSosCases/{caseId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && validOwnerSosCreate(request.auth.uid));
      allow update: if isAdmin() || (signedIn() && validOwnerSosUpdate(request.auth.uid));
      allow delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow get, list: if isAdmin() || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if signedIn() && validSupportTicketCreate();
      allow update: if (signedIn() && resource.data.requesterId == request.auth.uid && validOwnerTicketUpdate())
        || (isAdmin() && validAdminTicketUpdate());
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.requesterId == request.auth.uid
          );
        allow create: if (
          isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.requesterId == request.auth.uid
          )
        ) && validSupportTicketMessageCreate(ticketId);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
